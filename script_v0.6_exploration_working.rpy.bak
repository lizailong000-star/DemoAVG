# DemoAVG v0.6 - 探索型悬疑 AVG 原型
# 在 v0.5 章节化基础上，新增房间调查 / 探索菜单系统

init 0 python:
    # 最高优先级强制中文字体配置（simhei.ttf 已验证可用）
    style.default.font = "simhei.ttf"
    style.say_dialogue.font = "simhei.ttf"
    style.say_label.font = "simhei.ttf"
    style.menu_choice.font = "simhei.ttf"

# ===== 内置占位图层 =====

image bg_room_dark = Solid("#1a1c22", xysize=(1280, 720))
image char_placeholder = Solid("#222222", xysize=(420, 720))
image phone_off = Solid("#0a0a0a", xysize=(80, 140))
image phone_on = Solid("#e8f0ff", xysize=(80, 140))
image phone_ring_flash = Solid("#ffcc66", xysize=(80, 140))
image black_overlay = Solid("#000000", xysize=(1280, 720))
image phone_glow_strong = Solid("#f4f8ff", xysize=(90, 150))

# ===== 角色和变量定义 =====

define n = Character(None) # 旁白
define l = Character("周明", color="#c8c8c8") # 角色

default phone_answered = False

# v0.6 新增：调查线索状态
default clue_phone_checked = False
default clue_door_checked = False
default clue_window_checked = False
default clue_table_checked = False

# ===== 章节结构 =====

# --- 入口 ---
label start:
    jump chapter_01_start

# --- 第一章入口 ---
label chapter_01_start:
    jump intro_scene

# --- 开场 ---
label intro_scene:

    # 开场先全黑
    scene black with fade
    pause 0.7

    # 切到暗灰房间
    scene bg_room_dark with dissolve
    pause 0.6

    # 雨声渐入
    play music "audio/rain_loop.wav" loop fadein 2.0
    $ renpy.music.set_volume(0.65, delay=0.0, channel="music")

    n "雨声在窗外敲打着窗户，夜色潮湿而阴沉。"
    pause 0.6

    $ renpy.music.set_volume(0.8, delay=0.2, channel="music")
    pause 0.4
    $ renpy.music.set_volume(0.65, delay=0.3, channel="music")

    n "房间里只有手机屏幕发出微弱的光。"

    # 手机亮屏（强光闪一下）
    show phone_on:
        xpos 1150 ypos 530
    with dissolve
    show phone_glow_strong:
        xpos 1145 ypos 525
    pause 0.15
    hide phone_glow_strong
    show phone_on:
        xpos 1150 ypos 530

    pause 0.5

    show char_placeholder at center with dissolve

    l "这么晚，谁会打电话过来？"
    pause 0.6

    # v0.6 改为进入房间调查
    jump room_investigation_intro

# --- 房间调查引入 ---
label room_investigation_intro:

    n "电话没有立刻响。房间安静得有些不对劲。"
    n "你决定先看看四周。"

    jump room_investigation

# --- 房间调查菜单 ---
label room_investigation:

    menu:
        "调查手机":
            jump investigate_phone

        "调查门口":
            jump investigate_door

        "调查窗户":
            jump investigate_window

        "调查桌子":
            jump investigate_table

# --- 调查：手机 ---
label investigate_phone:

    if not clue_phone_checked:
        $ clue_phone_checked = True
        n "手机屏幕还亮着。"
        n "没有未接来电，也没有新短信。"
        n "可你总觉得它刚刚亮过。"
    else:
        n "手机还是那样安静地亮着。"

    jump check_investigation_progress

# --- 调查：门口 ---
label investigate_door:

    if not clue_door_checked:
        $ clue_door_checked = True
        n "门锁好好的。"
        n "但门缝下面有一点水迹，像是从外面渗进来的。"
    else:
        n "门口没有新的动静。"

    jump check_investigation_progress

# --- 调查：窗户 ---
label investigate_window:

    if not clue_window_checked:
        $ clue_window_checked = True
        n "窗外的雨很密。"
        n "楼下停着一辆没熄火的车，车灯一直亮着。"
    else:
        n "那辆车还停在楼下。"

    jump check_investigation_progress

# --- 调查：桌子 ---
label investigate_table:

    if not clue_table_checked:
        $ clue_table_checked = True
        n "桌上压着一张养老院宣传单。"
        n "宣传单角落被水打湿了，上面写着：明天上午九点。"
    else:
        n "那张宣传单还压在桌上。"

    jump check_investigation_progress

# --- 调查进度检查（触发条件：手机 + 桌子）---
label check_investigation_progress:

    if clue_phone_checked and clue_table_checked:
        n "就在你放下宣传单的时候，手机突然响了。"
        jump phone_event
    else:
        jump room_investigation

# --- 电话事件：手机熄屏 → 电话铃响 → 雨声压低 → 手机闪烁 ---
label phone_event:

    # 电话铃响前，手机熄灭一下
    hide phone_on
    show phone_off:
        xpos 1150 ypos 530
    pause 0.3

    # 电话铃响起，雨声压低
    show phone_ring_flash:
        xpos 1150 ypos 530
    play sound "audio/phone_ring.wav"
    $ renpy.music.set_volume(0.25, delay=0.2, channel="music")

    # 手机闪烁 5 次
    pause 0.16
    show phone_on:
        xpos 1150 ypos 530
    pause 0.16
    show phone_ring_flash:
        xpos 1150 ypos 530
    pause 0.16
    show phone_on:
        xpos 1150 ypos 530
    pause 0.16
    show phone_ring_flash:
        xpos 1150 ypos 530
    pause 0.16
    show phone_on:
        xpos 1150 ypos 530
    pause 0.16
    show phone_ring_flash:
        xpos 1150 ypos 530
    pause 0.16
    show phone_on:
        xpos 1150 ypos 530
    pause 0.16
    show phone_ring_flash:
        xpos 1150 ypos 530
    pause 0.16

    show phone_on:
        xpos 1150 ypos 530

    $ renpy.music.set_volume(0.65, delay=0.3, channel="music")
    pause 0.3

    jump phone_choice

# --- 玩家选择 ---
label phone_choice:

    menu:
        "接电话":
            $ phone_answered = True
            jump answer_phone

        "不接电话":
            $ phone_answered = False
            jump ignore_phone

# --- 分支：接电话 ---
label answer_phone:

    stop sound

    show phone_glow_strong:
        xpos 1145 ypos 525
    pause 0.2
    hide phone_glow_strong
    show phone_on:
        xpos 1150 ypos 530

    pause 0.5

    n "你把手机贴到耳边，雨声像是一下子远了。"

    $ renpy.music.set_volume(0.35, delay=0.4, channel="music")

    n "你接起电话，电话那头却是一片寂静。"
    l "喂？有人吗？"

    pause 0.8

    n "几秒钟后，一个低沉的声音透过听筒响起："

    scene black with dissolve
    pause 0.25
    scene bg_room_dark with dissolve
    show phone_on:
        xpos 1150 ypos 530

    n "“不要去养老院……”"

    $ renpy.music.set_volume(0.65, delay=0.5, channel="music")

    return

# --- 分支：不接电话 ---
label ignore_phone:

    stop sound

    hide phone_on
    hide phone_ring_flash
    show phone_off:
        xpos 1150 ypos 530
    with dissolve

    pause 0.7

    n "手机屏幕暗下去，房间像是突然空了一块。"

    $ renpy.music.set_volume(0.85, delay=0.2, channel="music")
    pause 0.5
    $ renpy.music.set_volume(0.55, delay=0.3, channel="music")

    pause 0.6

    play sound "audio/knock.wav"

    n "你选择不接电话，铃声慢慢停下。"
    n "但几秒后，门外传来了轻微的敲门声，让人不寒而栗。"

    pause 0.5

    show black_overlay with dissolve
    pause 0.25
    hide black_overlay with dissolve

    n "那三下不像敲门，更像是在确认你还在不在。"

    return
